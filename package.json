{
  "name": "stringly-typed",
  "version": "1.8.3",
  "author": "ddnetters",
  "description": "🎯 Stringly-Typed - AI-powered brand voice validation for your codebase. GitHub Action for string validation with precision.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/main.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --sourcemap",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "release:patch": "npm version patch && git push origin main --follow-tags",
    "release:minor": "npm version minor && git push origin main --follow-tags",
    "release:major": "npm version major && git push origin main --follow-tags",
    "prerelease": "npm run test && npm run typecheck && npm run bundle"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^7.0.0",
    "@semantic-release/git": "^10.0.1",
    "@types/glob": "^9.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.7.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.3.0",
    "jest": "^30.4.2",
    "semantic-release": "^25.0.8",
    "ts-jest": "^29.4.9",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.65.0"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@langchain/anthropic": "^1.5.1",
    "@langchain/aws": "^1.4.2",
    "@langchain/core": "^1.1.48",
    "@langchain/google-genai": "^2.2.0",
    "@langchain/openai": "^1.5.3",
    "glob": "^13.0.6",
    "langchain": "^1.5.2",
    "zod": "^4.4.3"
  }
}
